// Modelo de dados do LiteDock (control plane).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  name         String?
  role         String       @default("owner") // owner | admin | member
  totpSecret   String? // segredo TOTP (base32) — null = sem 2FA
  totpEnabled  Boolean      @default(false)
  // Incrementado a cada troca de senha ou revogação manual ("sair de todos os
  // dispositivos"). O JWT carrega o valor no momento da emissão (`tv`); o
  // decorator `authenticate` compara com o valor atual no banco a cada
  // requisição — se divergir, o token foi revogado (mesmo antes de expirar).
  tokenVersion Int          @default(0)
  createdAt    DateTime     @default(now())
  projects     Project[]
  credentials  Credential[]
}

// Servidor alvo. MVP = 1 local; preparado pra multi-node (agentes).
model Server {
  id             String    @id @default(uuid())
  name           String
  dockerEndpoint String    @default("unix:///var/run/docker.sock")
  publicIp       String?
  agentToken     String?
  status         String    @default("online")
  createdAt      DateTime  @default(now())
  services       Service[]
}

// Workspace que agrupa serviços.
model Project {
  id        String    @id @default(uuid())
  ownerId   String
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  createdAt DateTime  @default(now())
  services  Service[]
  bridgesA  ProjectBridge[] @relation("BridgeA")
  bridgesB  ProjectBridge[] @relation("BridgeB")

  @@unique([ownerId, slug])
  @@index([ownerId])
}

// Ponte de rede entre dois projetos (isolamento é o padrão; a ponte é opt-in).
// Quando existe, os containers de cada lado entram também na rede do outro.
model ProjectBridge {
  id        String   @id @default(uuid())
  aId       String
  bId       String
  a         Project  @relation("BridgeA", fields: [aId], references: [id], onDelete: Cascade)
  b         Project  @relation("BridgeB", fields: [bId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([aId, bId])
}

// Serviço = Aplicação OU Banco de dados. Config específica no JSON `spec`.
model Service {
  id          String       @id @default(uuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serverId    String
  server      Server       @relation(fields: [serverId], references: [id])
  name        String
  type        String // 'app' | 'database'
  status      String       @default("created") // created|deploying|running|stopped|error
  containerId String?
  deployToken String?      @unique // token do webhook de deploy (CI/CD on-push)
  spec        Json         @default("{}")
  createdAt   DateTime     @default(now())
  envVars     EnvVar[]
  domains     Domain[]
  deployments Deployment[]
  backups     Backup[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([serverId])
  @@index([status])
}

model EnvVar {
  id        String  @id @default(uuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  key       String
  value     String // cifrado (AES-GCM) em repouso
  isSecret  Boolean @default(true)

  @@unique([serviceId, key])
  @@index([serviceId])
}

model Domain {
  id         String   @id @default(uuid())
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  host       String   @unique
  targetPort Int
  https      Boolean  @default(true)
  certStatus String   @default("pending") // pending|active|error
  createdAt  DateTime @default(now())

  @@index([serviceId])
}

model Deployment {
  id         String    @id @default(uuid())
  serviceId  String
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status     String    @default("queued") // queued|building|deploying|success|failed
  trigger    String    @default("manual") // manual|webhook|api
  commitSha  String?
  imageTag   String?
  log        String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([serviceId, startedAt(sort: Desc)])
  @@index([status])
}

model Credential {
  id        String   @id @default(uuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  kind      String // github | gitlab | registry
  name      String
  token     String // cifrado
  createdAt DateTime @default(now())

  @@index([ownerId])
}

// Agendamento de liga/desliga de um container do host (diário, hora local).
model ContainerSchedule {
  id            String   @id @default(uuid())
  containerName String   @unique
  startTime     String? // "HH:MM" — liga nesse horário (diário)
  stopTime      String? // "HH:MM" — desliga nesse horário
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Backup {
  id        String   @id @default(uuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status    String   @default("pending")
  location  String?
  sizeBytes BigInt?
  createdAt DateTime @default(now())

  @@index([serviceId])
}

// Configurações gerais do painel (chave-valor). Ex.: domínio do painel,
// domínio de serviços, e-mail do Let's Encrypt, flags como limpeza diária.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
