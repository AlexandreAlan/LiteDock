# ── Banco (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL="postgresql://litedock:TROQUE_ESTA_SENHA@127.0.0.1:5440/litedock?schema=public"

# ── Redis (fila BullMQ) ─────────────────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6390"

# ── Auth (JWT) ─────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET="SUBSTITUA_POR_UM_SEGREDO_ALEATORIO_DE_64_CHARS"

# ── Criptografia de env vars em repouso (AES-256-GCM) ──────────────────
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY="SUBSTITUA_POR_UMA_CHAVE_ALEATORIA_DE_64_CHARS"

# ── API ────────────────────────────────────────────────────────────────
PORT=8088

# ── Traefik ────────────────────────────────────────────────────────────
TRAEFIK_NETWORK="litedock"

# ── Docker ─────────────────────────────────────────────────────────────
DOCKER_SOCKET="/var/run/docker.sock"
LITEDOCK_DOCKER_PROXY=127.0.0.1:2375

# ── URL pública (usada no webhook de deploy) ───────────────────────────
# Coloque o domínio público do seu painel (sem barra no final)
# PUBLIC_URL=https://meu-painel.dominio.com/api

# ── Postgres (senha do docker-compose.dev.yml) ─────────────────────────
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
