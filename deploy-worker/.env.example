# ── Autenticação (segredo compartilhado com o Node) ────────────────────────
# MESMO valor do DEPLOY_WORKER_TOKEN em ../.env (raiz do litedock-v2). Sem
# isso, o worker aceita chamadas de QUALQUER processo local sem autenticação
# — veja o aviso de boot e o comentário em main.py. Gere com: openssl rand -hex 32
DEPLOY_WORKER_TOKEN="SUBSTITUA_POR_UM_SEGREDO_ALEATORIO_DE_64_CHARS_IGUAL_AO_DO_NODE"

# ── Modo seguro (dry-run) ───────────────────────────────────────────────────
# true (padrão) = só retorna o "plano" do que faria, nunca toca no Docker.
# Só desligue depois de revisar o que cada endpoint faz (main.py).
# SAFE_MODE=false

# ── Rede/nomeação (mesmos defaults do Node, normalmente não precisa mexer) ──
# TRAEFIK_NETWORK=litedock
# CONTAINER_PREFIX=litedock
# TRAEFIK_CONTAINER=litedock-traefik
# PANEL_PM2_NAME=litedock-v2-api
